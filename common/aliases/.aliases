# commands
alias ls='ls -a'
alias cl='clear'
alias sz='source ~/.zshrc'

alias tmux='tmux -2 -u'
alias one='tmux -L one'
alias two='tmux -L two'
alias three='tmux -L three'
alias four='tmux -L four'

alias oc='opencode'

# directories
alias cb='cd ~/Developer/Git/Codeberg'
alias gh='cd ~/Developer/Git/Github'
alias dot='cd ~/Developer/Git/Codeberg/dotfiles'

alias dotw='ws -2 hx -3 claude three ~/Developer/Git/Codeberg/dotfiles dot'

alias clw='ws -2 hx -3 claude -4 "just up -p" one ~/Developer/Git/Github/Clad/clad'

# ws [-1 cmd] [-2 cmd] [-3 cmd] [-4 cmd] <server> [dir] [session]
ws() {
  local cmd1="" cmd2="" cmd3="" cmd4=""

  local OPTIND=1
  while getopts "1:2:3:4:" opt; do
    case "$opt" in
      1) cmd1="$OPTARG" ;;
      2) cmd2="$OPTARG" ;;
      3) cmd3="$OPTARG" ;;
      4) cmd4="$OPTARG" ;;
    esac
  done
  shift $((OPTIND - 1))

  local server="${1:?Usage: ws [-1 cmd] [-2 cmd] [-3 cmd] [-4 cmd] <server> [dir] [session]}"
  local dir="${2:-$PWD}"
  local session="${3:-$(basename "$dir")}"

  if ! _tmux has-session -t "$session" 2>/dev/null; then
    _ws "$server" "$dir" "$session" "$cmd1" "$cmd2" "$cmd3" "$cmd4"
  fi

  local wt_dir wt_session
  for wt_dir in "$dir".worktrees/*(/N); do
    wt_session="$(basename "$wt_dir")"
    _tmux has-session -t "$wt_session" 2>/dev/null && continue
    _ws "$server" "$wt_dir" "$wt_session" "$cmd1" "$cmd2" "$cmd3" "$cmd4"
  done

  _tmux attach-session -t "$session"
}

_ws() {
  local server="$1" dir="$2" session="$3"
  local cmds=("$4" "$5" "$6" "$7")

  for i in 1 2 3 4; do
    local cmd="${cmds[$i]}"

    if [[ $i -eq 1 ]]; then
      _tmux new-session -d -s "$session" -c "$dir"
    else
      _tmux new-window -t "$session:$i" -c "$dir"
    fi
    [[ -n "$cmd" ]] && _tmux send-keys -t "$session:$i" "$cmd" Enter
  done

  _tmux select-window -t "$session:1"
}

_tmux() { command tmux -2 -u -L "$server" "$@"; }
