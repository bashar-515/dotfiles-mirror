# commands
alias ls='ls -a'
alias cl='clear'
alias sz='source ~/.zshrc'

alias tmux='tmux -2 -u'
alias one='tmux -L one'
alias two='tmux -L two'
alias three='tmux -L three'
alias four='tmux -L four'

# directories
alias gh='cd ~/Developer/Git/Github'

alias dot='cd ~/Developer/Git/Github/dotfiles'
alias clad='cd ~/Developer/Git/Github/Clad/clad-dashboard'
