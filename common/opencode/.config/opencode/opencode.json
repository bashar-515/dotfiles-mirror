{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "bash": {
       "*": "ask",
       "git status*": "allow",
       "git log*": "allow",
       "git diff*": "allow"
     },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "task": "allow",
    "lsp": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow"
  }
}